# Anchorpoint Environment Configuration
# Copy this file to .env and fill in values

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Database (SQLite path, relative to backend/)
DATABASE_URL=sqlite:///./anchorpoint.db

# ChromaDB (vector memory, relative to backend/)
CHROMA_DB_PATH=./chroma_db

# CORS - comma-separated origins for local frontend dev
CORS_ORIGINS=http://localhost:5173

# LLM defaults
DEFAULT_MODEL=llama3.1:8b
CONTEXT_WINDOW_TOKENS=4096

# Debug mode
DEBUG=false

# Web Search (Ollama Web Search API — free account at ollama.com)
# Create an API key at: https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Weather (OpenWeatherMap free tier — openweathermap.org/api)
OPENWEATHERMAP_API_KEY=

# News (NewsAPI free tier — newsapi.org)
NEWS_API_KEY=

# Commute (Google Maps Directions API — console.cloud.google.com)
GOOGLE_MAPS_API_KEY=

# Google Calendar OAuth 2.0 (create an OAuth app at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/settings/integrations

# Encryption at rest (Sprint 4)
# Optional — leave blank to auto-generate a key in backend/.secret_key on first run.
# To set manually: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
