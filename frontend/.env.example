# Vite reads this file from the frontend/ directory (copy to frontend/.env).
# Google Cloud Console: OAuth client type "Web application".
# - Authorized JavaScript origins: http://localhost:5173
# - Authorized redirect URI: must match VITE_GOOGLE_REDIRECT_URI exactly.

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/settings/integrations
